<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Adaptive-icon background. The launcher applies its own mask (circle,
         square, squircle, …) so the layer just needs to fill 108×108 with the
         brand gradient. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="108">
                <item android:offset="0.0" android:color="#22C55E" />
                <item android:offset="1.0" android:color="#15803D" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
